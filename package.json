{
  "name": "pretty-color-picker",
  "version": "0.1.0",
  "description": "A beautiful, perceptually accurate color picker with OKLCH as the internal source of truth",
  "type": "module",
  "main": "./dist/pretty-color-picker.umd.cjs",
  "module": "./dist/pretty-color-picker.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pretty-color-picker.js",
      "require": "./dist/pretty-color-picker.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "color-picker",
    "oklch",
    "web-component",
    "culori"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "culori": "^4.0.2"
  }
}
