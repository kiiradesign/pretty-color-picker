{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:demo",
  "outputDirectory": "demo-dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(favicon\\.svg|pcp-opengraph\\.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
